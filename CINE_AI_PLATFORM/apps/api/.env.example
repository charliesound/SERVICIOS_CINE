APP_NAME=CINE AI PLATFORM API
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=3000
# For local dev frontend:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# For WSL+Nginx deployment, use:
# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# Legacy compatibility alias (optional):
# FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SHOTS_STORE_BACKEND=sqlite
SHOTS_JSON_FILE=./data/shots.json
SHOTS_SQLITE_FILE=./data/shots.db
RENDER_JOBS_SQLITE_FILE=./data/render_jobs.db
ENABLE_LEGACY_ROUTES=true
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_TIMEOUT_SECONDS=2.5
