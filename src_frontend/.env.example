# API base URL (proxy configurado en vite.config.ts)
VITE_API_URL=/api

# Título por defecto de la aplicación
VITE_APP_TITLE=AILinkCinema

# URL base de ComfyUI
VITE_COMFY_URL=http://localhost:8188

# ────────────────────────────────────────────
# Webhook n8n para formulario /demo-cid
# ────────────────────────────────────────────
# Configura aquí la URL del webhook de n8n que recibirá los leads
# del formulario "Prueba CID con tu guion".
#
# Formato esperado por n8n: POST JSON con Content-Type: application/json
# Campos enviados: nombre, email, empresa, rol, tipoProyecto, faseProyecto,
#                  objetivoPrincipal, enlaceGuion, mensaje, aceptaContacto,
#                  _timestamp, _source
#
# Ejemplo:
# VITE_DEMO_CID_WEBHOOK_URL=https://tu-instancia.n8n.cloud/webhook/cid-demo-lead
#
# Déjalo vacío si aún no tienes el webhook; el formulario mostrará
# un mensaje informativo en lugar de fallar silenciosamente.
VITE_DEMO_CID_WEBHOOK_URL=
