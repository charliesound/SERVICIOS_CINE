# AI Dubbing Legal Studio — Configuración

# App
APP_NAME="AI Dubbing Legal Studio"
APP_VERSION=1.0.0
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://dubbing:dubbing@localhost:5432/dubbing_legal

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# MinIO / S3
STORAGE_PROVIDER=local
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=dubbing
MINIO_SECRET_KEY=dubbing-secret
MINIO_BUCKET=dubbing-assets
STORAGE_LOCAL_PATH=./data/storage

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Qdrant (opcional)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Providers — usa "comfyui" para producción real, "mock" para desarrollo
TTS_PROVIDER=comfyui
LIPSYNC_PROVIDER=comfyui
ASR_PROVIDER=comfyui

# ComfyUI multi-instancia
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_STILL=http://127.0.0.1:8188
COMFYUI_VIDEO=http://127.0.0.1:8189
COMFYUI_DUBBING=http://127.0.0.1:8190
COMFYUI_LAB=http://127.0.0.1:8191

# LLM
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=

# Worker
WORKER_CONCURRENCY=2
COMFYUI_POLL_INTERVAL=2
COMFYUI_POLL_TIMEOUT=300
