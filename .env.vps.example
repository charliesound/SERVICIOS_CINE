# AILinkCinema - Environment Variables for VPS Deployment
# Copy to .env and adjust as needed

# ==========================================
# BACKEND
# ==========================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./ailinkcinema.db

# ==========================================
# AUTH
# ==========================================
AUTH_SECRET_KEY=change-me-in-production-use-strong-random-key
AUTH_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================================
# PUBLIC DOMAIN
# ==========================================
PUBLIC_HOST=ailinkcinema.example.com
PUBLIC_PROTOCOL=https
CUSTOM_DOMAIN=ailinkcinema.example.com

# ==========================================
# COMFYUI ENDPOINTS (via Tailscale from home machine)
# ==========================================
# Replace 100.x.x.x with actual Tailscale IP of home machine
COMFYUI_BASE_URL=http://100.x.x.x:8188
COMFYUI_STILL=http://100.x.x.x:8188
COMFYUI_VIDEO=http://100.x.x.x:8189
COMFYUI_DUBBING=http://100.x.x.x:8190
COMFYUI_LAB=http://100.x.x.x:8191

# ==========================================
# PORTS
# ==========================================
FRONTEND_PORT=3000
HTTP_PORT=80
HTTPS_PORT=443

# ==========================================
# CADDY (TLS)
# ==========================================
CADDY_BASIC_AUTH_USER=admin
CADDY_BASIC_AUTH_PASSWORD_HASH=