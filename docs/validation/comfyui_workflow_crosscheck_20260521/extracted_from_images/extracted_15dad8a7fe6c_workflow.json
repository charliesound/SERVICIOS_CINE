      "widgets_values": [
        false,
        "\u00f0\u009f\u0093\u009d Quick Tips:\n\n\u00e2\u0080\u00a2 'Use Input' takes text from input node\n\u00e2\u0080\u00a2 'Use Prompt' uses text from prompt box (input node won't run)\n\n\u00e2\u0080\u00a2 Prompt saves only if 'Save Name' is filled\n\u00e2\u0080\u00a2 Saving to an existing name overwrites it\n\n\u00e2\u0080\u00a2 Use 'List' dropdown to select prompt lists\n\u00e2\u0080\u00a2 Manage lists with the Prompt Stash Manager node\n\n\u00e2\u0080\u00a2 For real-time editing, use Prompt Stash Passthrough node with 'Pause to Edit'\n\u00e2\u0080\u00a2 If workflow closes while paused, use 'Clear Paused' in Manager node\n\n\u00e2\u0080\u00a2 Saved prompts persist between sessions\n\u00e2\u0080\u00a2 All nodes share the same prompt library",
        "Instructions",
        "Instructions",
        "default"
      ]
