# AILinkCinema - Environment Variables for Home Demo
# Copy to .env and adjust as needed.
# Los placeholders de este archivo no son operativos.
# No publicar el .env real ni reutilizar secretos.

# ==========================================
# BACKEND
# ==========================================
APP_ENV=demo
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./ailinkcinema.db
ENABLE_DEMO_ROUTES=1
ENABLE_EXPERIMENTAL_ROUTES=0
ENABLE_POSTPRODUCTION_ROUTES=0
QUEUE_PERSISTENCE_MODE=memory

# ==========================================
# AUTH OBLIGATORIO
# ==========================================
# Definir secretos fuertes y distintos.
AUTH_SECRET_KEY=AUTH_SECRET_KEY_REQUIRED_IN_ENV
APP_SECRET_KEY=APP_SECRET_KEY_REQUIRED_IN_ENV
AUTH_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================================
# INTEGRACIONES (solo si se usan)
# ==========================================
INTEGRATION_TOKEN_ENCRYPTION_KEY=INTEGRATION_TOKEN_ENCRYPTION_KEY_REQUIRED_IN_ENV
GOOGLE_DRIVE_OAUTH_STATE_SECRET=GOOGLE_DRIVE_OAUTH_STATE_SECRET_REQUIRED_IN_ENV
GOOGLE_DRIVE_CLIENT_ID=GOOGLE_DRIVE_CLIENT_ID_REQUIRED_IF_USED
GOOGLE_DRIVE_CLIENT_SECRET=GOOGLE_DRIVE_CLIENT_SECRET_REQUIRED_IF_USED

# ==========================================
# PUBLIC ACCESS (via Tailscale)
# ==========================================
LOCAL_WSL_IP=172.24.174.31
TAILSCALE_IP=100.121.83.126
PUBLIC_HOST=localhost
PUBLIC_PROTOCOL=http

# Recommended: Docker Tailscale sidecar for laptop access
TS_AUTHKEY=
TS_HOSTNAME=ailinkcinema-home-demo
TS_USERSPACE=false
TS_ACCEPT_DNS=false
TS_EXTRA_ARGS=

# ==========================================
# NETWORK BINDS (secure defaults)
# ==========================================
POSTGRES_BIND_ADDR=127.0.0.1
REDIS_BIND_ADDR=127.0.0.1
QDRANT_BIND_ADDR=127.0.0.1
QDRANT_GRPC_BIND_ADDR=127.0.0.1
N8N_BIND_ADDR=127.0.0.1
OLLAMA_BIND_ADDR=127.0.0.1

# ==========================================
# OLLAMA MODEL ROUTING (RTX 5090)
# ==========================================
# Docker backend should use service-to-service URL:
OLLAMA_BASE_URL=http://ollama:11434
# Native backend on host can use:
# OLLAMA_BASE_URL=http://127.0.0.1:11434

OLLAMA_MODEL=qwen2.5:14b
OLLAMA_SCRIPT_ANALYSIS_MODEL=qwen2.5:32b
OLLAMA_ANALYSIS_MODEL=qwen2.5:32b
OLLAMA_STORYBOARD_PROMPT_MODEL=qwen2.5:14b
OLLAMA_PIPELINE_BUILDER_MODEL=qwen2.5:14b
OLLAMA_QUICK_MODEL=qwen2.5:7b
OLLAMA_VISUAL_MODEL=qwen2.5:7b
OLLAMA_FALLBACK_MODEL=mistral:7b
OLLAMA_SMOKE_MODEL=tinyllama
OLLAMA_KEEP_ALIVE=30m
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1

# ==========================================
# COMFYUI DOCKER (5 services, no public exposure)
# ==========================================
# Validate image tag before first `docker compose up`.
COMFYUI_IMAGE=
COMFYUI_BIND_ADDR=127.0.0.1
COMFYUI_STILL_HOST_PORT=8188
COMFYUI_VIDEO_HOST_PORT=8189
COMFYUI_DUBBING_HOST_PORT=8190
COMFYUI_RESTORATION_HOST_PORT=8191
COMFYUI_3D_HOST_PORT=8192
# Para probar Docker still sin parar ComfyUI nativo:
# COMFYUI_STILL_HOST_PORT=8288

# CID backend -> ComfyUI Docker service URLs
COMFYUI_STILL_BASE_URL=http://comfyui-still:8188
COMFYUI_VIDEO_BASE_URL=http://comfyui-video:8189
COMFYUI_DUBBING_BASE_URL=http://comfyui-dubbing:8190
COMFYUI_RESTORATION_BASE_URL=http://comfyui-restoration:8191
COMFYUI_LAB_BASE_URL=http://comfyui-restoration:8191
COMFYUI_3D_BASE_URL=http://comfyui-3d:8192

# Native host paths for bind mounts
COMFYUI_STILL_MODELS_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-image/models
COMFYUI_VIDEO_MODELS_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-video_cine/models
COMFYUI_DUBBING_MODELS_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-dubbing_audio/models
COMFYUI_RESTORATION_MODELS_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-restoration/models
COMFYUI_3D_MODELS_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-image/models

COMFYUI_STILL_CUSTOM_NODES_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-image/custom_nodes
COMFYUI_VIDEO_CUSTOM_NODES_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-video_cine/custom_nodes
COMFYUI_DUBBING_CUSTOM_NODES_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-dubbing_audio/custom_nodes
COMFYUI_RESTORATION_CUSTOM_NODES_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-restoration/custom_nodes
COMFYUI_3D_CUSTOM_NODES_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-3D/custom_nodes

COMFYUI_STILL_INPUT_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-image/input
COMFYUI_VIDEO_INPUT_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-video_cine/input
COMFYUI_DUBBING_INPUT_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-dubbing_audio/input
COMFYUI_RESTORATION_INPUT_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-restoration/input
COMFYUI_3D_INPUT_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-3D/input

COMFYUI_STILL_OUTPUT_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-image/output
COMFYUI_VIDEO_OUTPUT_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-video_cine/output
COMFYUI_DUBBING_OUTPUT_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-dubbing_audio/output
COMFYUI_RESTORATION_OUTPUT_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-restoration/output
COMFYUI_3D_OUTPUT_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-3D/output

COMFYUI_STILL_USER_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-image/user
COMFYUI_VIDEO_USER_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-video_cine/user
COMFYUI_DUBBING_USER_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-dubbing_audio/user
COMFYUI_RESTORATION_USER_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-restoration/user
COMFYUI_3D_USER_DIR=/home/harliesound/ai/ComfyUI_instances/ComfyUI-3D/user

# Legacy aliases (optional compatibility)
COMFYUI_BASE_URL=http://comfyui-still:8188
COMFYUI_STORYBOARD_BASE_URL=http://comfyui-still:8188

# ==========================================
# PORTS
# ==========================================
FRONTEND_PORT=3000
HTTP_PORT=80
HTTPS_PORT=443
PUBLIC_NET_NAME=ailinkcinema_home_public
PRIVATE_NET_NAME=ailinkcinema_home_private
CADDY_DATA_NAME=ailinkcinema_home_caddy_data

# No publicar ni versionar: .env real, secretos, tokens OAuth, SQLite con datos reales,
# documentos subidos, PDFs de usuarios, logs sensibles ni outputs privados de clientes.
