# ComfySearch — Semantic Workflow Search for ComfyUI

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=comfy_workflows

# Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_PROVIDER=sentence_transformers

# ComfyUI multi-instancia
COMFYUI_STILL=http://127.0.0.1:8188
COMFYUI_VIDEO=http://127.0.0.1:8189
COMFYUI_DUBBING=http://127.0.0.1:8190
COMFYUI_LAB=http://127.0.0.1:8191

# Search
SEARCH_TOP_K=8

# Workflow roots (separados por coma)
WORKFLOW_ROOTS=/opt/SERVICIOS_CINE/src/comfyui_workflows,/mnt/g/COMFYUI_HUB/workflows

# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5055
FLASK_DEBUG=true
