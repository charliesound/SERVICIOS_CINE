    "end_at": {"node": "4", "input": "end_at"},
    "positive_prompt": {"node": "5", "input": "text"},
    "negative_prompt": {"node": "6", "input": "text"},
    "width": {"node": "7", "input": "width"},
    "height": {"node": "7", "input": "height"},
    "steps": {"node": "8", "input": "steps"},
    "cfg": {"node": "8", "input": "cfg"},
    "sampler_name": {"node": "8", "input": "sampler_name"},
    "scheduler": {"node": "8", "input": "scheduler"},
    "seed": {"node": "8", "input": "seed"},
    "denoise": {"node": "8", "input": "denoise"},
    "output_prefix": {"node": "10", "input": "filename_prefix"}
  },
  "defaults": {
    "checkpoint": "FLUX/flux1-dev-fp8.safetensors",
    "ipadapter_model": "FLUX/instantx_flux1_dev_ip_adapter_bf16.safetensors",
