      "negative": ["7", 0],
      "latent_image": ["5", 0],
      "denoise": 1
    }
  },
  "4": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "{{CHECKPOINT_NAME}}"
    }
  },
  "5": {
