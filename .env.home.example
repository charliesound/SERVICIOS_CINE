# AILinkCinema - Environment Variables for Home Demo
# Copy to .env and adjust as needed

# ==========================================
# BACKEND
# ==========================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./ailinkcinema.db

# ==========================================
# AUTH
# ==========================================
AUTH_SECRET_KEY=change-me-in-production-use-strong-random-key
AUTH_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================================
# PUBLIC ACCESS (via Tailscale)
# ==========================================
LOCAL_WSL_IP=172.24.174.31
TAILSCALE_IP=100.x.x.x
PUBLIC_HOST=localhost
PUBLIC_PROTOCOL=http

# Recommended: Docker Tailscale sidecar for laptop access
TS_AUTHKEY=tskey-client-change-me
TS_HOSTNAME=ailinkcinema-home-demo
TS_USERSPACE=false
TS_ACCEPT_DNS=false
TS_EXTRA_ARGS=

# ==========================================
# COMFYUI ENDPOINTS (on local machine, not Docker)
# ==========================================
# Point to host.docker.internal for local ComfyUI running outside Docker
COMFYUI_BASE_URL=http://host.docker.internal:8188
COMFYUI_STILL=http://host.docker.internal:8188
COMFYUI_VIDEO=http://host.docker.internal:8189
COMFYUI_DUBBING=http://host.docker.internal:8190
COMFYUI_LAB=http://host.docker.internal:8191

# ==========================================
# PORTS
# ==========================================
FRONTEND_PORT=3000
HTTP_PORT=80
HTTPS_PORT=443
