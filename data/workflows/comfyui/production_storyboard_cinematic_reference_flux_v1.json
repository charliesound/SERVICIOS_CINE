    "provider": "cuda",
    "ipadapter_weight": 0.85,
    "start_at": 0.0,
    "end_at": 1.0,
    "width": 1344,
    "height": 768,
    "steps": 20,
    "cfg": 3.5,
    "sampler_name": "euler",
    "scheduler": "normal",
    "seed": 0,
    "denoise": 1.0,
    "output_prefix": "storyboard_reference"
  },
  "prompt_template": {
    "1": {
      "inputs": {
        "ckpt_name": "FLUX/flux1-dev-fp8.safetensors"
      },
      "class_type": "CheckpointLoaderSimple"
    },
    "2": {
