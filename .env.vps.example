# AILinkCinema - Environment Variables for VPS Deployment
# Copy to .env and adjust as needed.
# Los placeholders de este archivo no son operativos.
# Este template sirve para demo controlada; TLS/443 sigue pendiente de validacion final.

# ==========================================
# BACKEND
# ==========================================
APP_ENV=production
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./ailinkcinema.db
ENABLE_DEMO_ROUTES=0
ENABLE_EXPERIMENTAL_ROUTES=0
ENABLE_POSTPRODUCTION_ROUTES=0
QUEUE_PERSISTENCE_MODE=memory

# ==========================================
# AUTH OBLIGATORIO
# ==========================================
# Definir secretos fuertes y distintos.
AUTH_SECRET_KEY=AUTH_SECRET_KEY_REQUIRED_IN_ENV
APP_SECRET_KEY=APP_SECRET_KEY_REQUIRED_IN_ENV
AUTH_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================================
# INTEGRACIONES (solo si se usan)
# ==========================================
INTEGRATION_TOKEN_ENCRYPTION_KEY=INTEGRATION_TOKEN_ENCRYPTION_KEY_REQUIRED_IN_ENV
GOOGLE_DRIVE_OAUTH_STATE_SECRET=GOOGLE_DRIVE_OAUTH_STATE_SECRET_REQUIRED_IN_ENV
GOOGLE_DRIVE_CLIENT_ID=GOOGLE_DRIVE_CLIENT_ID_REQUIRED_IF_USED
GOOGLE_DRIVE_CLIENT_SECRET=GOOGLE_DRIVE_CLIENT_SECRET_REQUIRED_IF_USED

# ==========================================
# PUBLIC DOMAIN
# ==========================================
PUBLIC_HOST=ailinkcinema.example.com
PUBLIC_PROTOCOL=https
CUSTOM_DOMAIN=ailinkcinema.example.com

# ==========================================
# REMOTE AI SERVICES OVER TAILSCALE
# ==========================================
# VPS without GPU.
# Heavy AI services run on the home GPU server over Tailscale.
# Replace 100.x.x.x with the Tailscale IP or MagicDNS name of the home GPU server.
OLLAMA_BASE_URL=http://100.x.x.x:11434
COMFYUI_STILL_BASE_URL=http://100.x.x.x:8188
COMFYUI_VIDEO_BASE_URL=http://100.x.x.x:8189
COMFYUI_DUBBING_BASE_URL=http://100.x.x.x:8190
COMFYUI_RESTORATION_BASE_URL=http://100.x.x.x:8191
COMFYUI_LAB_BASE_URL=http://100.x.x.x:8191
COMFYUI_3D_BASE_URL=http://100.x.x.x:8192

# Legacy compatibility keys (keep aligned with *_BASE_URL values)
COMFYUI_BASE_URL=http://100.x.x.x:8188
COMFYUI_STORYBOARD_BASE_URL=http://100.x.x.x:8188
COMFYUI_STILL=http://100.x.x.x:8188
COMFYUI_VIDEO=http://100.x.x.x:8189
COMFYUI_DUBBING=http://100.x.x.x:8190
COMFYUI_LAB=http://100.x.x.x:8191

OLLAMA_MODEL=qwen2.5:14b
OLLAMA_SCRIPT_ANALYSIS_MODEL=qwen2.5:32b
OLLAMA_ANALYSIS_MODEL=qwen2.5:32b
OLLAMA_STORYBOARD_PROMPT_MODEL=qwen2.5:14b
OLLAMA_PIPELINE_BUILDER_MODEL=qwen2.5:14b
OLLAMA_QUICK_MODEL=qwen2.5:7b
OLLAMA_VISUAL_MODEL=qwen2.5:7b
OLLAMA_FALLBACK_MODEL=mistral:7b
OLLAMA_SMOKE_MODEL=tinyllama

# ==========================================
# PORTS
# ==========================================
FRONTEND_PORT=3000
HTTP_PORT=80
HTTPS_PORT=443
PUBLIC_NET_NAME=ailinkcinema_vps_public
PRIVATE_NET_NAME=ailinkcinema_vps_private
CADDY_DATA_NAME=ailinkcinema_vps_caddy_data

# ==========================================
# LEGACY / FUTURE TLS PLACEHOLDERS
# ==========================================
CADDY_BASIC_AUTH_USER=admin
CADDY_BASIC_AUTH_PASSWORD_HASH=

# No publicar ni versionar: .env real, secretos, tokens OAuth, SQLite con datos reales,
# documentos subidos, PDFs de usuarios, logs sensibles ni outputs privados de clientes.
