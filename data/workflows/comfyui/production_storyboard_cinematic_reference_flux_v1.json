      },
      "class_type": "IPAdapterFluxLoader"
    },
    "4": {
      "inputs": {
        "weight": 0.85,
        "start_at": 0.0,
        "end_at": 1.0,
        "image": ["2", 0],
        "model": ["1", 0],
        "ipadapter": ["3", 0]
      },
      "class_type": "ApplyIPAdapterFlux"
    },
    "5": {
      "inputs": {
        "text": "cinematic establishing shot, professional lighting, consistent character appearance, matching wardrobe",
        "clip": ["1", 1]
      },
      "class_type": "CLIPTextEncode"
    },
    "6": {
      "inputs": {
        "text": "distorted face, inconsistent clothing, color shift, text, watermark, deformed body",
        "clip": ["1", 1]
      },
      "class_type": "CLIPTextEncode"
    },
    "7": {
      "inputs": {
        "width": 1344,
        "height": 768,
        "batch_size": 1
      },
      "class_type": "EmptyLatentImage"
    },
    "8": {
      "inputs": {
        "seed": 246802468,
        "steps": 20,
        "cfg": 3.5,
        "sampler_name": "euler",
        "scheduler": "normal",
        "denoise": 1.0,
        "model": ["4", 0],
        "positive": ["5", 0],
        "negative": ["6", 0],
        "latent_image": ["7", 0]
      },
      "class_type": "KSampler"
    },
    "9": {
      "inputs": {
        "samples": ["8", 0],
        "vae": ["1", 2]
      },
      "class_type": "VAEDecode"
    },
    "10": {
      "inputs": {
        "filename_prefix": "storyboard_reference",
        "images": ["9", 0]
      },
      "class_type": "SaveImage"
    }
  }
