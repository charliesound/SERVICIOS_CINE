# =============================================================================
# AILinkCinema — Enterprise Environment Template
# =============================================================================
# This file documents ALL configuration variables recognised by the platform.
# Copy to .env and customise for your environment.
# =============================================================================

# ── DATA STACK / DOCKER ────────────────────────────────────────────────────
# PostgreSQL (profile: with-postgres in compose.data.yml)
POSTGRES_USER=ailinkcinema
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ailinkcinema
POSTGRES_BIND_ADDR=127.0.0.1
POSTGRES_PORT=5432
# DATABASE_URL for Docker PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://ailinkcinema:change-me@postgres:5432/ailinkcinema

# Redis optional (profile: with-redis in compose.data.yml)
REDIS_PASSWORD=
REDIS_BIND_ADDR=127.0.0.1
REDIS_PORT=6379
# REDIS_URL=redis://redis:6379/0

# Qdrant (profile: with-qdrant in compose.data.yml)
QDRANT_HOST=qdrant
QDRANT_BIND_ADDR=127.0.0.1
QDRANT_PORT=6333
QDRANT_GRPC_BIND_ADDR=127.0.0.1
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=comfy_workflows

# 127.0.0.1 is safest for local host access.
# For remote laptop access, prefer Tailscale Serve or Caddy instead of binding sensitive services to 0.0.0.0.
# Do not expose PostgreSQL, Redis, Qdrant or Ollama publicly.

# ── APP ───────────────────────────────────────────────────────────────────
APP_NAME=AILinkCinema
APP_ENV=development              # development | staging | production | test
APP_VERSION=1.0.0
APP_DEBUG=false

# ── AUTH / JWT ENTERPRISE ─────────────────────────────────────────────────
# JWT_SECRET: Minimum 32 characters. Must be strong in production.
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ISSUER=ailinkcinema
JWT_AUDIENCE=cid-api
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Set AUTH_DISABLED=true only in development for local testing
# NEVER enable in production (validated at startup)
AUTH_DISABLED=false

# Legacy fallback (used by old config layer)
AUTH_SECRET_KEY=
APP_SECRET_KEY=

# ── DATABASE ──────────────────────────────────────────────────────────────
# Examples:
#   SQLite:  sqlite+aiosqlite:///./ailinkcinema_s2.db
#   PostgreSQL: postgresql+asyncpg://user:pass@host:5432/ailinkcinema
DATABASE_URL=sqlite+aiosqlite:///./ailinkcinema_s2.db

# ── REDIS (optional, for rate limiting / queue) ───────────────────────────
REDIS_URL=

# ── INTERNAL API KEY (optional, for service-to-service) ───────────────────
INTERNAL_API_KEY_ENABLED=false
# Comma-separated list of valid internal API keys
INTERNAL_API_KEYS=

# ── RATE LIMIT ────────────────────────────────────────────────────────────
# memory | redis (redis driver not yet wired, prepares for future)
RATE_LIMIT_BACKEND=memory
LOGIN_RATE_LIMIT_PER_MINUTE=10

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In production, '*' is NOT allowed.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── LOGGING ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR | CRITICAL
REQUEST_ID_HEADER=X-Request-ID

# ── HEALTH CHECKS ─────────────────────────────────────────────────────────
HEALTHCHECK_DB_ENABLED=true
HEALTHCHECK_REDIS_ENABLED=false

# ── FEATURE FLAGS ─────────────────────────────────────────────────────────
FEATURE_WORKFLOWS=true
FEATURE_PRESETS=true
FEATURE_PLANS=true
FEATURE_QUEUE=true
FEATURE_ADMIN=true
FEATURE_EXPERIMENTAL=false
FEATURE_POSTPRODUCTION=false

# ── CINEMATIC TAXONOMY / VISUAL BIBLE ────────────────────────────────
VISUAL_BIBLE_STORYBOARD_ENRICHMENT_ENABLED=false

# ── QUEUE ─────────────────────────────────────────────────────────────────
QUEUE_PERSISTENCE_MODE=memory     # memory | database

# ── DEMO ──────────────────────────────────────────────────────────────────
DEMO_ENABLED=false
DEMO_AUTO_SEED_NARRATIVE=false
ENABLE_DEMO_ROUTES=false

# ── STORAGE ───────────────────────────────────────────────────────────────
STORAGE_TYPE=local
STORAGE_DATA_DIR=data
STORAGE_TEMP_DIR=data/temp
STORAGE_OUTPUT_DIR=data/output

# ── OLLAMA / Local LLM ─────────────────────────────────────────────
LLM_PROVIDER=ollama

# Native dev on host:
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Docker backend:
# OLLAMA_BASE_URL=http://ollama:11434
# VPS without GPU, proxying to home GPU server over Tailscale:
# OLLAMA_BASE_URL=http://100.x.x.x:11434

# Default balanced model
OLLAMA_MODEL=qwen2.5:14b

# Task-specific models
OLLAMA_SCRIPT_ANALYSIS_MODEL=qwen2.5:32b
OLLAMA_ANALYSIS_MODEL=qwen2.5:32b
OLLAMA_STORYBOARD_PROMPT_MODEL=qwen2.5:14b
OLLAMA_PIPELINE_BUILDER_MODEL=qwen2.5:14b
OLLAMA_QUICK_MODEL=qwen2.5:7b
OLLAMA_VISUAL_MODEL=qwen2.5:7b
OLLAMA_FALLBACK_MODEL=mistral:7b
OLLAMA_SMOKE_MODEL=tinyllama

OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_KEEP_ALIVE=30m

LLM_TIMEOUT_SECONDS=240
LLM_TEMPERATURE=0.2
SCRIPT_ANALYSIS_PROVIDER=ollama
STORYBOARD_PROMPT_PROVIDER=ollama
PIPELINE_BUILDER_PROVIDER=ollama
LLM_ENABLE_FALLBACK=true

# ── OLLAMA Docker ─────────────────────────────────────────────────
OLLAMA_IMAGE=ollama/ollama:latest
OLLAMA_BIND_ADDR=127.0.0.1
OLLAMA_PORT=11434
OLLAMA_VOLUME_NAME=ailinkcinema_ollama_data
# Optional bind mount instead of named volume:
# OLLAMA_VOLUME=/home/your-user/.ollama

# ── COMFYSEARCH (semantic workflow search) ────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=comfy_workflows
COMFYSEARCH_ROOTS=
COMFYSEARCH_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── CID RAG (project documents + screenwriting theory) ───────────────────
PROJECT_DOCUMENT_EMBEDDING_PROVIDER=local_hash
PROJECT_DOCUMENT_RAG_USE_QDRANT=false
PROJECT_DOCUMENT_QDRANT_COLLECTION=project_document_chunks
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_TIMEOUT_SECONDS=30

# ── CID MEMORY / EMBEDDINGS PIPELINE ─────────────────────────────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text:v1.5
EMBEDDING_VECTOR_SIZE=768
OLLAMA_URL=http://ollama:11434
CID_MEMORY_COLLECTION=cid_memory

# ── CID RAG ANSWER ENDPOINT ───────────────────────────────────────────────
RAG_LLM_PROVIDER=ollama
RAG_LLM_MODEL=qwen2.5:14B
RAG_LLM_TEMPERATURE=0.2
RAG_MAX_CONTEXT_CHUNKS=5
RAG_MAX_CHARS_PER_CHUNK=1200
RAG_MAX_PROMPT_CHARS=8000
RAG_LLM_TIMEOUT_SECONDS=60
RAG_LLM_NUM_PREDICT=512

# ── INSTANCE CONFIG ───────────────────────────────────────────────────────
# Path to YAML with backend instance definitions
INSTANCE_CONFIG_PATH=

# ── COMFYUI INSTANCE REGISTRY ────────────────────────────────────────────
# Path to ComfyUI instances YAML definition
COMFYUI_INSTANCES_CONFIG=src/config/comfyui_instances.yml
# Per-task backend URL overrides (recommended: WSL/Linux local instances)
# Replace <WSL_IP> with the output of: hostname -I | awk '{print $1}'
COMFYUI_STILL_BASE_URL=http://<WSL_IP>:8188
COMFYUI_VIDEO_BASE_URL=http://<WSL_IP>:8189
COMFYUI_DUBBING_BASE_URL=http://<WSL_IP>:8190
COMFYUI_RESTORATION_BASE_URL=http://<WSL_IP>:8191
COMFYUI_LAB_BASE_URL=http://<WSL_IP>:8191
COMFYUI_3D_BASE_URL=http://<WSL_IP>:8192
# Legacy aliases (optional compatibility)
COMFYUI_BASE_URL=http://<WSL_IP>:8188
COMFYUI_STORYBOARD_BASE_URL=http://<WSL_IP>:8188
# Timeouts
COMFYUI_HTTP_TIMEOUT=300
COMFYUI_TIMEOUT_SECONDS=300
COMFYUI_HEALTH_TIMEOUT_SECONDS=5
COMFYUI_POLL_INTERVAL_SECONDS=2

# ── COMFYUI DOCKER ────────────────────────────────────────────────────────
# NOT RECOMMENDED for local dev. Use WSL/Linux instances instead.
# Docker ComfyUI (yanwk/comfyui-boot) currently has dependency issues
# (nunchaku, natsort, agents conflicts) — see docs/validation/comfyui_wsl_architecture_20260520.md
#
# Examples to evaluate:
# COMFYUI_IMAGE=aidockorg/comfyui-cuda:<tag>
# COMFYUI_IMAGE=<your-custom-comfyui-image>
# COMFYUI_IMAGE=yanwk/comfyui-boot:cu130-slim
# COMFYUI_IMAGE=yanwk/comfyui-boot:cu128-slim
COMFYUI_IMAGE=
COMFYUI_BIND_ADDR=127.0.0.1
COMFYUI_STILL_HOST_PORT=8188
COMFYUI_VIDEO_HOST_PORT=8189
COMFYUI_DUBBING_HOST_PORT=8190
COMFYUI_RESTORATION_HOST_PORT=8191
COMFYUI_3D_HOST_PORT=8192
# For yanwk/comfyui-boot images, ComfyUI root is /root/ComfyUI.
# Avoid megapak tags for CID backend if they bootstrap-download large models.
# Prefer slim/no-megapak tags to reuse host-mounted models.
COMFYUI_CONTAINER_ROOT=/root/ComfyUI

# ── COMFYUI HOST PATHS ────────────────────────────────────────────────────
# Windows:
#   Models: I:\COMFYUI_OK\models
#   Hub:    G:\COMFYUI_HUB
#
# WSL/Docker:
COMFYUI_MODELS_BASE_DIR=/mnt/i/COMFYUI_OK/models
COMFYUI_HUB_DIR=/mnt/g/COMFYUI_HUB

COMFYUI_INPUT_DIR=/mnt/g/COMFYUI_HUB/input
COMFYUI_WORKFLOWS_DIR=/mnt/g/COMFYUI_HUB/workflows

COMFYUI_OUTPUT_STILL_DIR=/mnt/g/COMFYUI_HUB/output/still
COMFYUI_OUTPUT_VIDEO_DIR=/mnt/g/COMFYUI_HUB/output/video
COMFYUI_OUTPUT_DUBBING_DIR=/mnt/g/COMFYUI_HUB/output/dubbing
COMFYUI_OUTPUT_RESTORATION_DIR=/mnt/g/COMFYUI_HUB/output/restoration
COMFYUI_OUTPUT_3D_DIR=/mnt/g/COMFYUI_HUB/output/3d

COMFYUI_USER_STILL_DIR=/mnt/g/COMFYUI_HUB/user/still
COMFYUI_USER_VIDEO_DIR=/mnt/g/COMFYUI_HUB/user/video
COMFYUI_USER_DUBBING_DIR=/mnt/g/COMFYUI_HUB/user/dubbing
COMFYUI_USER_RESTORATION_DIR=/mnt/g/COMFYUI_HUB/user/restoration
COMFYUI_USER_3D_DIR=/mnt/g/COMFYUI_HUB/user/3d

# Keep per-instance custom_nodes if required by each profile.
COMFYUI_STILL_CUSTOM_NODES_DIR=
COMFYUI_VIDEO_CUSTOM_NODES_DIR=
COMFYUI_DUBBING_CUSTOM_NODES_DIR=
COMFYUI_RESTORATION_CUSTOM_NODES_DIR=
COMFYUI_3D_CUSTOM_NODES_DIR=

# ── NETWORK / DEPLOYMENT ──────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_PREFIX=/api

# ── INTEGRATIONS (optional) ───────────────────────────────────────────────
# n8n Integration
N8N_ENABLED=false
N8N_BASE_URL=http://127.0.0.1:5678
N8N_WEBHOOK_SECRET=
N8N_DEFAULT_TIMEOUT_SECONDS=10
N8N_TEST_WEBHOOK_PATH=/webhook/cid-test

INTEGRATION_TOKEN_ENCRYPTION_KEY=
GOOGLE_DRIVE_OAUTH_STATE_SECRET=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=

# ── CADDY (reverse proxy) ─────────────────────────────────────────────────
CADDY_BASIC_AUTH_USER=admin
CADDY_BASIC_AUTH_PASSWORD_HASH=

# ── DOMAIN / PUBLIC URLS ──────────────────────────────────────────────────
# Cuando se despliegue con dominio propio (Cloudflare Tunnel / VPS)
PUBLIC_APP_URL=https://app.tudominio.com
PUBLIC_API_URL=https://api.tudominio.com
PUBLIC_DEMO_URL=https://demo.tudominio.com
PUBLIC_N8N_URL=
PUBLIC_FLOWISE_URL=

# ── CLOUDFLARE TUNNEL ────────────────────────────────────────────────────
# Configurar en Cloudflare Zero Trust → Networks → Tunnels
# NO guardar tokens reales en este archivo ni en git
CLOUDFLARE_TUNNEL_NAME=
CLOUDFLARE_TUNNEL_ID=

# ── CORS ──────────────────────────────────────────────────────────────────
# Lista separada por comas de orígenes permitidos para CORS.
# Local:
#   CORS_ALLOWED_ORIGINS=http://localhost:80,http://127.0.0.1:80
# Dominio:
#   CORS_ALLOWED_ORIGINS=https://app.tudominio.com,https://demo.tudominio.com
CORS_ALLOWED_ORIGINS=

# ── INTERNAL SERVICE URLs (Docker compose hostnames) ──────────────────────
# Estas URLs se resuelven dentro de la red Docker. No cambiar a 127.0.0.1 a
# menos que el servicio corra fuera de Docker.
# QDRANT_URL tiene prioridad sobre QDRANT_HOST:QDRANT_PORT en el backend.
QDRANT_URL=http://qdrant:6333
# N8N_URL=http://n8n:5678
# FLOWISE_URL=http://flowise:3000

# ── GPU WORKER ────────────────────────────────────────────────────────────
# local = GPU en el mismo host que el backend
# remote = GPU en otro host (VPS → PC local por Tailscale/WireGuard)
GPU_WORKER_MODE=local
GPU_WORKER_BASE_URL=
COMFYUI_IMAGE_URL=
COMFYUI_VIDEO_URL=
COMFYUI_AUDIO_URL=
COMFYUI_RESTORATION_URL=
COMFYUI_3D_URL=
OLLAMA_URL=

# ── BACKEND BIND ─────────────────────────────────────────────────────────
# 127.0.0.1 para no exponer públicamente. Usar reverse proxy o túnel.
BACKEND_HOST=127.0.0.1

# ── N8N / Workflow automation (optional) ───────────────────────────
# Use a specific tag for reproducibility, e.g. n8nio/n8n:1.123.24
# Avoid n8nio/n8n:latest in production.
N8N_IMAGE=n8nio/n8n:1
N8N_ENCRYPTION_KEY=change-me-minimum-32-chars
N8N_HOST=localhost
N8N_BIND_ADDR=127.0.0.1
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678
N8N_API_KEY=
N8N_DB_TABLE_PREFIX=n8n_
N8N_DB_POOL_SIZE=3
N8N_EXECUTIONS_DATA_PRUNE=true
N8N_EXECUTIONS_DATA_MAX_AGE=336
N8N_PERSONALIZATION_ENABLED=false
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
GENERIC_TIMEZONE=Europe/Madrid

# ── LEGACY / DEMO NETWORK ─────────────────────────────────────────────────
LOCAL_WSL_IP=172.24.174.31
TAILSCALE_IP=100.104.219.15
PUBLIC_HOST=ailinkcinema
PUBLIC_PROTOCOL=http
CUSTOM_DOMAIN=ailinkcinema
API_BASE_URL=http://backend:8000
CINE_CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8080
CINE_FRONTEND_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# =============================================================================
# SECURITY NOTICE: Do NOT commit real secrets (.env) to version control.
# =============================================================================

# ── DUBBING BRIDGE ──────────────────────────────────────────────────────
DUBBING_API_URL=http://127.0.0.1:8000
