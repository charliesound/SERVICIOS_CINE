# Docker compose runtime variables for Windows + WSL deployment

APP_NAME=CINE AI PLATFORM API
APP_ENV=production

# Host ports
API_PORT_BIND=3000
WEB_PORT_BIND=8080

# Backend storage settings
SHOTS_STORE_BACKEND=sqlite
RENDER_JOBS_SQLITE_FILE=/app/data/render_jobs.db

# API gateway and browser CORS origins
# Use exact origin(s) used in runtime (localhost, tailnet URL or tunnel URL)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Legacy route switch (recommended false in server deployment)
ENABLE_LEGACY_ROUTES=false

# Frontend build-time API base for nginx reverse proxy
VITE_API_BASE_URL=/api

# ComfyUI endpoint on host machine (NOT exposed via compose)
COMFYUI_BASE_URL=http://host.docker.internal:8188
COMFYUI_TIMEOUT_SECONDS=2.5
