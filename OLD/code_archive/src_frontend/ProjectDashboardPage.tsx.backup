         </section>
         
         {/* Comercial Phase */}
         <section className="space-y-4">
           <h2 className="heading-md">Comercial</h2>
           <div className="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
              {[ 'producer_pack', 'distribution', 'crm' ]
                .filter(key => modules.some(m => m.key === key))
                .map(key => {
                  const module = modules.find(m => m.key === key)!
                  const Icon = getModuleIcon(key)
                  const route = getModuleRoute(key, projectId)
                  return (
                    <Link
                      key={key}
                      to={route}
                      className="card card-hover"
                    >
                      <div className="flex items-start gap-4">
                        <div className="p-3 rounded-xl bg-dark-300">
                          <Icon className="w-5 h-5 text-amber-400" />
                        </div>
                        <div className="flex-1 min-w-0">
                          <div className="flex items-center justify-between gap-2">
                            <h3 className="font-semibold text-white capitalize">
                              {MODULE_DISPLAY_NAMES[key]}
                            </h3>
                            <StatusBadge status={module.status} size="sm" />
                          </div>
                          <p className="mt-1 text-sm text-slate-400 truncate">
                            {module.summary}
                          </p>
                        </div>
                      </div>
                    </Link>
                  )
                })}
           </div>
         </section>
         
         {/* Postproducción Phase */}
         <section className="space-y-4">
           <h2 className="heading-md">Postproducción</h2>
           <div className="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
              {[ 'media', 'documents' ]
                .filter(key => modules.some(m => m.key === key))
                .map(key => {
                  const module = modules.find(m => m.key === key)!
                  const Icon = getModuleIcon(key)
                  const route = getModuleRoute(key, projectId)
                  return (
                    <Link
                      key={key}
                      to={route}
                      className="card card-hover"
                    >
                      <div className="flex items-start gap-4">
                        <div className="p-3 rounded-xl bg-dark-300">
