BACKEND_PORT=8000

# ==========================================
# DATABASE (futuro)
# ==========================================
# DATABASE_URL=sqlite:///./servicios_cine.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/servicios_cine

# ==========================================
# REDIS (opcional)
