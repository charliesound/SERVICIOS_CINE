COMPOSE_PROJECT_NAME=ailinkcinema-vps

# Database (SQLite persistent or PostgreSQL if supported)
DATABASE_URL=sqlite+aiosqlite:////app/data/ailinkcinema_s2.db

# Secrets (MUST be changed before deploy)
AUTH_SECRET_KEY=CHANGE_ME_AUTH_SECRET_KEY_32_CHARS_MIN
APP_SECRET_KEY=CHANGE_ME_APP_SECRET_KEY_32_CHARS_MIN

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
PYTHONUNBUFFERED=1

# Frontend
# Served by Caddy on port 80/443, VITE_API_URL is built-time
# If accessing backend directly, set to http://your-domain.com/api

# ComfyUI (external services, NOT exposed publicly)
COMFYUI_STILL_URL=http://host.docker.internal:8188
COMFYUI_VIDEO_URL=http://host.docker.internal:8189
COMFYUI_DUBBING_URL=http://host.docker.internal:8190
COMFYUI_LAB_URL=http://host.docker.internal:8191

# CORS
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Queue
QUEUE_PERSISTENCE_MODE=db

# Demo (optional)
HOST_DEMO_INGEST_PATH=/srv/ailinkcinema/demo_ingest
