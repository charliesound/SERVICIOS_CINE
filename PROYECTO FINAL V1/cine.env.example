# Backend CINE_AI_PLATFORM
ENVIRONMENT=production
PORT=3000

# URL interna hacia ComfyUI
COMFYUI_BASE_URL=http://host.docker.internal:8188

# Checkpoint / defaults
COMFYUI_CHECKPOINT=v1-5-pruned-emaonly-fp16.safetensors
COMFYUI_NEGATIVE_PROMPT=blurry, bad anatomy, distorted, extra fingers, watermark
COMFYUI_WIDTH=1344
COMFYUI_HEIGHT=768

# Seguridad mínima si tu API la usa
STORYBOARD_API_KEYS=REEMPLAZAR_TOKEN_LARGO
STORYBOARD_CORS_ORIGINS=http://TU_IP_LOCAL:8080
STORYBOARD_UPSTREAM_TIMEOUT_SECONDS=120
STORYBOARD_HEALTH_TIMEOUT_SECONDS=10
