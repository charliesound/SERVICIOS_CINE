# Remote demo profile for deploy/docker-compose.wsl.yml

APP_NAME=CINE AI PLATFORM API
APP_ENV=demo

# Expose only web/nginx to host
WEB_PORT_BIND=8080

# Use official storage backend
SHOTS_STORE_BACKEND=sqlite
RENDER_JOBS_SQLITE_FILE=/app/data/render_jobs.db

# Harden demo surface
ENABLE_LEGACY_ROUTES=false

# Set EXACT remote origin used during demo
# Tailscale example:
# CORS_ORIGINS=http://cine-server.tailnet.ts.net:8080
# Cloudflare Tunnel example:
# CORS_ORIGINS=https://cine-demo.example.com
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Frontend talks through nginx /api
VITE_API_BASE_URL=/api

# ComfyUI stays external to Docker
COMFYUI_BASE_URL=http://host.docker.internal:8188
COMFYUI_TIMEOUT_SECONDS=2.5

# Optional demo proxy basic auth (used only with --with-basic-auth)
# DEMO_BASIC_AUTH_USER=demo
# DEMO_BASIC_AUTH_PASS=change-me
