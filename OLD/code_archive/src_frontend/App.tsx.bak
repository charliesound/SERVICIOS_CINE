import { Routes, Route, Navigate, useLocation } from 'react-router-dom'
import Layout from './components/Layout'
import ProtectedRoute from './components/ProtectedRoute'
import Dashboard from './pages/Dashboard'
import CreateJob from './pages/CreateJob'
import QueuePage from './pages/QueuePage'
import WorkflowsPage from './pages/WorkflowsPage'
import PlansPage from './pages/PlansPage'
import AdminPage from './pages/AdminPage'
import LoginPage from './pages/LoginPage'
import ProjectHistory from './pages/ProjectHistory'
import ClientPortal from './pages/ClientPortal'
import ProjectsPage from './pages/ProjectsPage'
import ProjectDetailPage from './pages/ProjectDetailPage'
import VisualPipelinePage from './pages/VisualPipelinePage'
import SceneVisualWorkspacePage from './pages/SceneVisualWorkspacePage'
import VisualShotListPage from './pages/VisualShotListPage'
import VisualAssetGalleryPage from './pages/VisualAssetGalleryPage'
import VisualAssetDetailPage from './pages/VisualAssetDetailPage'
import PostProductionPage from './pages/PostProductionPage'
import SceneClipsPage from './pages/SceneClipsPage'
import ClipsOverviewPage from './pages/ClipsOverviewPage'
import AssemblyDetailPage from './pages/AssemblyDetailPage'
import ReviewsOverviewPage from './pages/ReviewsOverviewPage'
import ReviewDetailPage from './pages/ReviewDetailPage'
import DeliveryOverviewPage from './pages/DeliveryOverviewPage'
import DeliverableDetailPage from './pages/DeliverableDetailPage'
import ProducerDashboardPage from './pages/ProducerDashboardPage'
import FundingListPage from './pages/FundingListPage'
import FundingDetailPage from './pages/FundingDetailPage'
import DemoRequestPage from './pages/DemoRequestPage'
import SavedOpportunitiesPage from './pages/SavedOpportunitiesPage'
import LandingPage from './pages/LandingPage'
import { useDemoGuard } from '@/hooks/useDemoMode'

function DemoRouteGuard({ children }: { children: React.ReactNode }) {
  const location = useLocation()
  const { getRedirect } = useDemoGuard()
  
  const redirect = getRedirect(location.pathname)
  
  if (redirect) {
    return <Navigate to={redirect} replace />
  }
  
  return <>{children}</>
}

export default function App() {
  return (
    <Routes>
      <Route path="/login" element={<LoginPage />} />
      
      {/* Public portal for clients */}
      <Route path="/project/:jobId" element={<ClientPortal />} />
      
      {/* Landing page - public, no layout */}
      <Route path="/landing" element={<LandingPage />} />
      
      <Route path="/" element={<Layout />}>
        <Route index element={<ProtectedRoute><Dashboard /></ProtectedRoute>} />
        <Route path="create" element={<ProtectedRoute><CreateJob /></ProtectedRoute>} />
        <Route path="queue" element={<ProtectedRoute><QueuePage /></ProtectedRoute>} />
        <Route path="history" element={<ProtectedRoute><ProjectHistory /></ProtectedRoute>} />
        <Route path="workflows" element={<ProtectedRoute><WorkflowsPage /></ProtectedRoute>} />
        <Route path="plans" element={<ProtectedRoute><PlansPage /></ProtectedRoute>} />
        <Route path="admin" element={
          <ProtectedRoute>
            <DemoRouteGuard>
              <AdminPage />
            </DemoRouteGuard>
          </ProtectedRoute>
        } />
        <Route path="projects" element={<ProtectedRoute><ProjectsPage /></ProtectedRoute>} />
        <Route path="projects/:projectId" element={<ProtectedRoute><ProjectDetailPage /></ProtectedRoute>} />
        <Route path="projects/:projectId/visual" element={<ProtectedRoute><VisualPipelinePage /></ProtectedRoute>} />
        <Route path="projects/:projectId/visual/scenes/:sceneId" element={<ProtectedRoute><SceneVisualWorkspacePage /></ProtectedRoute>} />
        <Route path="projects/:projectId/visual/shots" element={<ProtectedRoute><VisualShotListPage /></ProtectedRoute>} />
        <Route path="projects/:projectId/visual/assets" element={<ProtectedRoute><VisualAssetGalleryPage /></ProtectedRoute>} />
        <Route path="projects/:projectId/visual/assets/:assetId" element={<ProtectedRoute><VisualAssetDetailPage /></ProtectedRoute>} />
        <Route path="projects/:projectId/postproduction" element={<ProtectedRoute><PostProductionPage /></ProtectedRoute>} />
        <Route path="projects/:projectId/postproduction/scenes/:sceneId" element={<ProtectedRoute><SceneClipsPage /></ProtectedRoute>} />
        <Route path="projects/:projectId/postproduction/clips" element={<ProtectedRoute><ClipsOverviewPage /></ProtectedRoute>} />
        <Route path="projects/:projectId/postproduction/assemblies/:assemblyId" element={<ProtectedRoute><AssemblyDetailPage /></ProtectedRoute>} />
        <Route path="projects/:projectId/reviews" element={<ProtectedRoute><ReviewsOverviewPage /></ProtectedRoute>} />
        <Route path="projects/:projectId/reviews/:reviewId" element={<ProtectedRoute><ReviewDetailPage /></ProtectedRoute>} />
        <Route path="projects/:projectId/delivery" element={<ProtectedRoute><DeliveryOverviewPage /></ProtectedRoute>} />
        <Route path="projects/:projectId/delivery/:deliverableId" element={<ProtectedRoute><DeliverableDetailPage /></ProtectedRoute>} />
        <Route path="producer" element={<ProtectedRoute><ProducerDashboardPage /></ProtectedRoute>} />
        <Route path="producer/funding" element={<ProtectedRoute><FundingListPage /></ProtectedRoute>} />
        <Route path="producer/funding/:id" element={<ProtectedRoute><FundingDetailPage /></ProtectedRoute>} />
        <Route path="producer/demo" element={<ProtectedRoute><DemoRequestPage /></ProtectedRoute>} />
        <Route path="producer/saved" element={<ProtectedRoute><SavedOpportunitiesPage /></ProtectedRoute>} />
      </Route>
    </Routes>
  )
}
