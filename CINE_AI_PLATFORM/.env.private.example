APP_NAME=CINE AI PLATFORM API
APP_ENV=production
ENABLE_LEGACY_ROUTES=false
SHOTS_STORE_BACKEND=sqlite

NGINX_PORT_BIND=80
VITE_API_BASE_URL=/api

PRIVATE_BASE_URL=http://CHANGE_ME_TAILSCALE_HOSTNAME
PRIVATE_BROWSER_ORIGINS=http://127.0.0.1,http://localhost,http://CHANGE_ME_TAILSCALE_HOSTNAME

N8N_HOST=CHANGE_ME_TAILSCALE_HOSTNAME
N8N_EDITOR_BASE_URL=http://CHANGE_ME_TAILSCALE_HOSTNAME/n8n/
N8N_WEBHOOK_URL=http://CHANGE_ME_TAILSCALE_HOSTNAME/n8n/
N8N_ENCRYPTION_KEY=CHANGE_ME_N8N_ENCRYPTION_KEY_MIN_32_CHARS

GENERIC_TIMEZONE=Europe/Madrid

COMFYUI_BASE_URL=http://host.docker.internal:8188
COMFYUI_HOST_PROBE_URL=http://127.0.0.1:8188/system_stats
COMFYUI_TIMEOUT_SECONDS=5.0

AUTH_SESSION_TTL_DAYS=30
AUTH_BOOTSTRAP_USERS=CHANGE_ME_AUTH_BOOTSTRAP_USERS

API_DATA_PATH=X:\CINE_AI_PLATFORM\storage\api\data
N8N_DATA_PATH=X:\CINE_AI_PLATFORM\storage\n8n\data
QDRANT_STORAGE_PATH=X:\CINE_AI_PLATFORM\storage\qdrant\storage
NGINX_LOG_PATH=X:\CINE_AI_PLATFORM\storage\nginx\logs